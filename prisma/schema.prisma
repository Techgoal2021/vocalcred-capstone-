generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  phone           String?   @unique
  email           String?   @unique
  emailVerified   DateTime?
  name            String?
  businessName    String?
  businessType    String?
  role            String    @default("ARTISAN") // ARTISAN or CLIENT
  image           String?
  vocalcred_id    String?   @unique
  skill           String?
  jobs_completed  Int       @default(0)
  avg_rating      Float     @default(0.0)
  repeat_clients  Int       @default(0)
  reputation      Int?
  skill_score     Int?
  loan_score      Int?
  payer_score     Int?      @default(500)
  has_voice       Boolean   @default(true)
  language        String?   @default("en")
  pendingVoiceAction String?
  bio             String?
  instagram       String?
  twitter         String?
  website         String?
  portfolio       PortfolioItem[]
  achievements    Achievement[]
  accounts        Account[]
  sessions        Session[]
}

model PortfolioItem {
  id        String   @id @default(cuid())
  userId    String
  imageUrl  String
  caption   String?
  type      String   @default("PRODUCT") // PRODUCT, PROCESS, BEFORE_AFTER
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Achievement {
  id        String   @id @default(cuid())
  userId    String
  title     String
  date      DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([phone, code])
}
